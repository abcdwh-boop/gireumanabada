rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // 로그인한 본인의 user 문서 (같은 요청 안에서는 1회만 읽힘)
    function myData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole()  { return signedIn() ? myData().role : ''; }

    function isAdmin() { return signedIn() && myRole() == 'admin'; }
    function isVip()   { return signedIn() && myRole() == 'vip'; }
    // 상인 행위(판매·마켓지정·정산) 가능: 상인 + 담임 + 교사 + 관리자
    function canSell() { return signedIn() && (myRole() in ['merchant', 'vip', 'teacher', 'admin']); }

    // 이번 update 에서 바뀐 필드 집합
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ── 사용자 ─────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if signedIn();        // 로그인 시 다른 사용자 조회 가능(구매자/판매자/명단)
      allow create: if isAdmin();         // 명단 생성은 관리자만
      allow delete: if isAdmin();

      allow update: if signedIn() && (
        // (1) 본인 문서: wishlist / mustChangePassword / balance(±1)만, G캐시 상한 6
        ( request.auth.uid == uid
          && changedKeys().hasOnly(['wishlist', 'mustChangePassword', 'balance'])
          && request.resource.data.balance >= resource.data.balance - 1
          && request.resource.data.balance <= resource.data.balance + 1
          && ( request.resource.data.balance <= 6                          // 6 이하면 OK
               || request.resource.data.balance <= resource.data.balance ) // 6 초과는 '증가'만 차단(감소·유지는 허용)
        )

        // (2) 관리자: 무엇이든 (role 포함)
        || isAdmin()

        // (3) 담임(vip): '자기 반'의 '학생/상인' 계정을, '학생/상인'으로만, role 한 칸만 변경
        //     grade/classNo 가 문자열로 저장돼 있어도 되도록 int() 로 비교
        || ( isVip()
             && changedKeys().hasOnly(['role'])
             && int(resource.data.grade)   == int(myData().grade)
             && int(resource.data.classNo) == int(myData().classNo)
             && resource.data.role          in ['student', 'merchant']
             && request.resource.data.role  in ['student', 'merchant']
           )

        // (4) 판매 정산: 상인/담임/교사/관리자가 balance·leaf 등 갱신 — 단, role 은 절대 못 바꿈
        || ( canSell() && !changedKeys().hasAny(['role']) )
      );
    }

    // ── 물품 ───────────────────────────────────────────────
    match /items/{itemId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.sellerUid == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.sellerUid == request.auth.uid
        || canSell()
      );
      allow delete: if isAdmin();
    }

    // ── 물품번호 채번 ──────────────────────────────────────
    match /counters/{key} {
      allow read:  if signedIn();
      allow write: if signedIn();
    }

    // ── 학급 리프 집계 ─────────────────────────────────────
    match /classStats/{key} {
      allow read:  if true;
      allow write: if canSell();
    }

    // ── 설정 ───────────────────────────────────────────────
    match /config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}